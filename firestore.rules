rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /banners/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /posts/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /partners/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
